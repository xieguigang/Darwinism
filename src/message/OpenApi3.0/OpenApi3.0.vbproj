<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-windows;net10.0</TargetFrameworks>
    <Platforms>AnyCPU;x64</Platforms>
    <Configurations>Debug;Release;LipidSearch;Rsharp_app_release;mzkit;gcmodeller_desktop;nuget_release</Configurations>
    <OutputType>Exe</OutputType>
    <RootNamespace>Darwinism.IPC.OpenApi3</RootNamespace>
    <AssemblyName>Darwinism.IPC.OpenApi3.0</AssemblyName>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
    <AssemblyTitle>OpenApi3.0 Source Generator</AssemblyTitle>
    <UseApplicationFramework>True</UseApplicationFramework>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\sciBASIC#\Microsoft.VisualBasic.Core\src\Core.vbproj" />
    <ProjectReference Include="..\..\..\..\sciBASIC#\mime\text%yaml\text.yaml.vbproj" />
  </ItemGroup>

</Project>